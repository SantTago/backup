from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from selenium.webdriver.common.keys import Keys
from selenium.webdriver.firefox.options import Options
from selenium.common.exceptions import UnexpectedAlertPresentException, NoAlertPresentException
import time
import os

class TorInstagramBot:
    def __init__(self, instagram_links):
        self.instagram_links = instagram_links
        self.driver = None
        
    def dismiss_all_alerts(self):
        """Fecha TODOS os alerts"""
        for _ in range(10):
            try:
                alert = self.driver.switch_to.alert
                alert.dismiss()
                print("✅ Alert fechado")
                time.sleep(1)
            except NoAlertPresentException:
                break
            except:
                break
    
    def start_tor_browser(self):
        """🔥 ABRE TOR BROWSER NOVO"""
        tor_path = r"C:\Users\SAMSUNG\Desktop\Tor Browser\Browser\firefox.exe"
        
        if not os.path.exists(tor_path):
            print(f"❌ Tor não encontrado: {tor_path}")
            return False
        
        print("🚀 ABRINDO TOR BROWSER NOVO...")
        options = Options()
        options.binary_location = tor_path
        
        # Configurações TOR
        options.set_preference("network.proxy.type", 1)
        options.set_preference("network.proxy.socks", "127.0.0.1")
        options.set_preference("network.proxy.socks_port", 9050)
        options.set_preference("network.proxy.socks_remote_dns", True)
        options.set_preference("network.proxy.socks_version", 5)
        
        self.driver = webdriver.Firefox(options=options)
        self.driver.maximize_window()
        time.sleep(8)
        print("✅ Tor aberto!")
        return True
    
    def connect_tor(self):
        """1️⃣ Clica CONECTAR"""
        print("🔌 CLICANDO CONECTAR...")
        self.dismiss_all_alerts()
        
        try:
            connect_selectors = [
                "//button[contains(text(),'Connect')]",
                "//*[contains(text(),'Connect')]",
                "//button[contains(@class,'primary')]",
                "//button[@id='connect']"
            ]
            
            for selector in connect_selectors:
                try:
                    btn = WebDriverWait(self.driver, 10).until(
                        EC.element_to_be_clickable((By.XPATH, selector))
                    )
                    btn.click()
                    print("✅ CONECTAR CLICADO!")
                    time.sleep(8)
                    return True
                except:
                    continue
            
            print("⚠️ Nenhum botão Connect - continuando...")
            return True
        except:
            print("⚠️ Connect pulado")
            return True
    
    def go_to_leofame(self):
        """2️⃣ Vai para Leofame"""
        print("🌐 INDO PARA LEOFAME...")
        self.driver.get("https://leofame.com/pr/free-instagram-views")
        time.sleep(10)
        self.dismiss_all_alerts()
        print("✅ Leofame carregado!")
    
    def process_single_link(self, ig_link):
        """🔥 PROCESSA 1 LINK COMPLETO"""
        print(f"\n📎 LINK: {ig_link}")
        
        # 1. Campo Instagram
        campo_selectors = [
            "//input[contains(@placeholder,'Link do Post do Instagram')]",
            "//input[contains(@placeholder,'Link do Post')]",
            "//input[contains(@placeholder,'Instagram')]",
            "//textarea[contains(@placeholder,'Link')]",
            "//input[contains(@name,'link')]"
        ]
        
        campo = None
        for selector in campo_selectors:
            try:
                campo = WebDriverWait(self.driver, 10).until(
                    EC.presence_of_element_located((By.XPATH, selector))
                )
                campo.clear()
                campo.send_keys(ig_link)
                print("✅ LINK COLADO!")
                time.sleep(3)
                break
            except:
                continue
        
        if not campo:
            print("❌ Campo não encontrado!")
            return False
        
        # 2. Botão Leofame
        print("🖱️ CLICANDO BOTÃO...")
        button_selectors = [
            "//button[contains(text(),'Obter visualizações gratuita')]",
            "//button[contains(text(),'Obter visualizações')]",
            "//button[contains(text(),'visualizações gratuita')]",
            "//*[contains(text(),'Obter visualizações gratuita')]",
            "//button[contains(text(),'Get free story views')]",
            "//button[contains(text(),'Get free')]",
        ]
        
        botao = None
        for selector in button_selectors:
            try:
                botao = WebDriverWait(self.driver, 8).until(
                    EC.element_to_be_clickable((By.XPATH, selector))
                )
                print(f"✅ BOTÃO ENCONTRADO!")
                self.driver.execute_script("arguments[0].scrollIntoView({block: 'center'});", botao)
                time.sleep(2)
                self.driver.execute_script("arguments[0].click();", botao)
                print("✅ BOTÃO CLICADO!")
                break
            except:
                continue
        
        # 🔥 3. ESPERA 70 SEGUNDOS (CORRIGIDO!)
        print("⏳ ESPERANDO 70 SEGUNDOS...")
        time.sleep(70)  # ✅ 70 SEGUNDOS EXATOS
        print("✅ 70 SEGUNDOS CONCLUÍDOS!")
        return True
    
    def close_browser(self):
        """🔒 FECHA NAVEGADOR COMPLETO"""
        print("🔒 FECHANDO NAVEGADOR...")
        if self.driver:
            self.driver.quit()
            self.driver = None
        time.sleep(5)
        print("✅ Navegador fechado!")
    
    def run(self):
        """🔥 PROCESSA TODOS LINKS - 1 por 1 com TOR NOVO"""
        print("🤖 TOR INSTAGRAM BOT - 1 LINK = 1 TOR")
        print("=" * 60)
        
        for i, link in enumerate(self.instagram_links):
            print(f"\n🔥 LINK {i+1}/{len(self.instagram_links)}")
            print(f"📎 {link}")
            print("=" * 60)
            
            # 🔥 TOR NOVO para cada link
            if not self.start_tor_browser():
                continue
            
            try:
                self.connect_tor()
                self.go_to_leofame()
                self.process_single_link(link)
            finally:
                # 🔒 SEMPRE fecha após 70s
                self.close_browser()
            
            print(f"✅ LINK {i+1} FINALIZADO!\n")
        
        print("\n🎉 🎉 TODOS LINKS CONCLUÍDOS! 🎉 🎉")
        input("\n⏹️ Enter para fechar...")

